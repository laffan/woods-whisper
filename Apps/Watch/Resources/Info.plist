<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleDisplayName</key>
    <string>Woods Whisper</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- Modern single-target SwiftUI watch app -->
    <key>WKApplication</key>
    <true/>
    <!-- Associates this watch app with its companion iPhone app (kept in sync via project.yml) -->
    <key>WKCompanionAppBundleIdentifier</key>
    <string>$(WW_COMPANION_BUNDLE_ID)</string>

    <!-- Microphone capture on the Watch -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Woods Whisper records audio on your Watch to send to your paired iPhone or iPad.</string>

    <!-- Direct Watch -> iPad over the local network (no companion phone) -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Woods Whisper sends your recordings directly to your paired iPad over WiFi, with no internet involved.</string>

    <!-- Direct Watch -> iPad over Bluetooth, for when there is no WiFi at all -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Woods Whisper sends your recordings directly to your paired iPad over Bluetooth when no WiFi is available.</string>

    <key>WKBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- Deep link used by the "New Recording" complication to start a recording -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.woodswhisper.app.record</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>woodswhisper</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
