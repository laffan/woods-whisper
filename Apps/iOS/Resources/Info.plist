<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleDisplayName</key>
    <string>Woods Whisper</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>

    <!-- Microphone capture -->
    <key>NSMicrophoneUsageDescription</key>
    <string>Woods Whisper records audio so it can transcribe your voice on-device.</string>

    <!-- Direct Watch -> iPad transfer over the local network -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>Woods Whisper receives recordings directly from your Apple Watch over your local WiFi network, with no internet involved.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_woodswhisper._tcp</string>
    </array>

    <!-- Direct Watch -> iPad transfer over Bluetooth (works with no WiFi at all) -->
    <key>NSBluetoothAlwaysUsageDescription</key>
    <string>Woods Whisper receives recordings directly from your Apple Watch over Bluetooth when no WiFi is available.</string>

    <!-- Keep recording/transcribing and advertising over Bluetooth when backgrounded -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
        <string>bluetooth-peripheral</string>
    </array>

    <key>UILaunchScreen</key>
    <dict/>

    <!-- iPad multitasking eligibility. An app is only re-laid-out (rather than bitmap-scaled)
         as its window resizes in Split View / Slide Over / Stage Manager when it (a) ships a
         launch screen, (b) supports all four iPad orientations, and (c) does not require full
         screen. Missing these, iPadOS renders the UI at a fixed size and scales it down — text
         and buttons shrink and the window won't go below ~half the screen. Declaring them makes
         the SwiftUI layout reflow responsively at every window width instead. -->
    <key>UIRequiresFullScreen</key>
    <false/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- Receive audio shared from other apps (share sheet / "Open in…"). Imported clips are
         treated like a normal recording and land in the Inbox. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Audio</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.audio</string>
                <string>public.mpeg-4-audio</string>
                <string>com.apple.m4a-audio</string>
                <string>public.mp3</string>
                <string>com.microsoft.waveform-audio</string>
                <string>public.aiff-audio</string>
            </array>
        </dict>
    </array>
    <key>LSSupportsOpeningDocumentsInPlace</key>
    <true/>

    <!-- Deep link used by the Lock Screen widget to start a recording -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>com.woodswhisper.app.record</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>woodswhisper</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
